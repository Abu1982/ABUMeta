{
  "$defs": {
    "AgentAssessment": {
      "additionalProperties": false,
      "description": "单个 Agent 的分析结果。",
      "properties": {
        "agent_id": {
          "description": "Agent 标识",
          "title": "Agent Id",
          "type": "string"
        },
        "agent_name": {
          "description": "Agent 名称",
          "title": "Agent Name",
          "type": "string"
        },
        "focus": {
          "description": "Agent 关注维度",
          "title": "Focus",
          "type": "string"
        },
        "risk_score": {
          "description": "风险分",
          "maximum": 100,
          "minimum": 0,
          "title": "Risk Score",
          "type": "integer"
        },
        "risk_level": {
          "description": "风险等级",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Risk Level",
          "type": "string"
        },
        "confidence": {
          "description": "结论置信度",
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "evidence": {
          "description": "证据点",
          "items": {
            "type": "string"
          },
          "title": "Evidence",
          "type": "array"
        },
        "missing_information": {
          "description": "待补信息",
          "items": {
            "type": "string"
          },
          "title": "Missing Information",
          "type": "array"
        },
        "next_actions": {
          "description": "建议动作",
          "items": {
            "type": "string"
          },
          "title": "Next Actions",
          "type": "array"
        }
      },
      "required": [
        "agent_id",
        "agent_name",
        "focus",
        "risk_score",
        "risk_level",
        "confidence",
        "evidence",
        "missing_information",
        "next_actions"
      ],
      "title": "AgentAssessment",
      "type": "object"
    },
    "AgentRosterEntry": {
      "additionalProperties": false,
      "description": "预警协同中的 Agent 定义。",
      "properties": {
        "agent_id": {
          "description": "Agent 唯一标识",
          "title": "Agent Id",
          "type": "string"
        },
        "agent_name": {
          "description": "Agent 展示名称",
          "title": "Agent Name",
          "type": "string"
        },
        "focus": {
          "description": "Agent 负责的风险维度",
          "title": "Focus",
          "type": "string"
        }
      },
      "required": [
        "agent_id",
        "agent_name",
        "focus"
      ],
      "title": "AgentRosterEntry",
      "type": "object"
    },
    "CoordinatedWarning": {
      "additionalProperties": false,
      "description": "多 Agent 协同后的样本预警。",
      "properties": {
        "sample_id": {
          "description": "样本编号",
          "title": "Sample Id",
          "type": "string"
        },
        "scenario_name": {
          "description": "样本标题",
          "title": "Scenario Name",
          "type": "string"
        },
        "counterparty_name": {
          "description": "对手方名称",
          "title": "Counterparty Name",
          "type": "string"
        },
        "scenario_snapshot": {
          "$ref": "#/$defs/ScenarioSnapshot",
          "description": "场景快照"
        },
        "overall_risk_score": {
          "description": "综合风险分",
          "maximum": 100,
          "minimum": 0,
          "title": "Overall Risk Score",
          "type": "integer"
        },
        "overall_risk_level": {
          "description": "综合风险等级",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "title": "Overall Risk Level",
          "type": "string"
        },
        "coordination_confidence": {
          "description": "协同置信度",
          "maximum": 1,
          "minimum": 0,
          "title": "Coordination Confidence",
          "type": "number"
        },
        "primary_risk_vector": {
          "description": "主风险向量",
          "title": "Primary Risk Vector",
          "type": "string"
        },
        "disposition": {
          "description": "最终处置策略",
          "enum": [
            "pass",
            "observe",
            "gated_continue",
            "block"
          ],
          "title": "Disposition",
          "type": "string"
        },
        "decision_band_label": {
          "description": "解释层决策标签",
          "title": "Decision Band Label",
          "type": "string"
        },
        "decision_reason": {
          "description": "解释层决策原因",
          "title": "Decision Reason",
          "type": "string"
        },
        "explanation_tags": {
          "description": "解释层标签",
          "items": {
            "type": "string"
          },
          "title": "Explanation Tags",
          "type": "array"
        },
        "external_conflict_level": {
          "description": "外部风险冲突级别",
          "title": "External Conflict Level",
          "type": "string"
        },
        "external_match_count": {
          "description": "外部风险命中数",
          "minimum": 0,
          "title": "External Match Count",
          "type": "integer"
        },
        "external_match_sources": {
          "description": "外部命中来源",
          "items": {
            "type": "string"
          },
          "title": "External Match Sources",
          "type": "array"
        },
        "external_resolution_advice": {
          "description": "外部建议处置动作",
          "title": "External Resolution Advice",
          "type": "string"
        },
        "external_conflict_summary": {
          "additionalProperties": true,
          "description": "外部多源冲突裁决摘要",
          "title": "External Conflict Summary",
          "type": "object"
        },
        "blocking_issues": {
          "description": "阻断项",
          "items": {
            "type": "string"
          },
          "title": "Blocking Issues",
          "type": "array"
        },
        "final_recommendation": {
          "description": "最终建议",
          "title": "Final Recommendation",
          "type": "string"
        },
        "recommended_owner": {
          "description": "建议责任方",
          "title": "Recommended Owner",
          "type": "string"
        },
        "coordination_adjustments": {
          "description": "协调层补偿与加权记录",
          "items": {
            "type": "string"
          },
          "title": "Coordination Adjustments",
          "type": "array"
        },
        "immediate_actions": {
          "description": "立即动作",
          "items": {
            "type": "string"
          },
          "title": "Immediate Actions",
          "type": "array"
        },
        "agent_assessments": {
          "description": "三 Agent 明细",
          "items": {
            "$ref": "#/$defs/AgentAssessment"
          },
          "title": "Agent Assessments",
          "type": "array"
        }
      },
      "required": [
        "sample_id",
        "scenario_name",
        "counterparty_name",
        "scenario_snapshot",
        "overall_risk_score",
        "overall_risk_level",
        "coordination_confidence",
        "primary_risk_vector",
        "disposition",
        "decision_band_label",
        "decision_reason",
        "explanation_tags",
        "external_conflict_level",
        "external_match_count",
        "external_match_sources",
        "external_resolution_advice",
        "blocking_issues",
        "final_recommendation",
        "recommended_owner",
        "immediate_actions",
        "agent_assessments"
      ],
      "title": "CoordinatedWarning",
      "type": "object"
    },
    "ReportSummary": {
      "additionalProperties": false,
      "description": "报告总览。",
      "properties": {
        "total_samples": {
          "description": "样本总数",
          "minimum": 0,
          "title": "Total Samples",
          "type": "integer"
        },
        "critical_count": {
          "description": "critical 样本数",
          "minimum": 0,
          "title": "Critical Count",
          "type": "integer"
        },
        "high_count": {
          "description": "high 样本数",
          "minimum": 0,
          "title": "High Count",
          "type": "integer"
        },
        "medium_count": {
          "description": "medium 样本数",
          "minimum": 0,
          "title": "Medium Count",
          "type": "integer"
        },
        "low_count": {
          "description": "low 样本数",
          "minimum": 0,
          "title": "Low Count",
          "type": "integer"
        },
        "blocked_count": {
          "description": "阻断样本数",
          "minimum": 0,
          "title": "Blocked Count",
          "type": "integer"
        },
        "top_warning_sample_ids": {
          "description": "优先关注样本",
          "items": {
            "type": "string"
          },
          "title": "Top Warning Sample Ids",
          "type": "array"
        },
        "dominant_risk_vectors": {
          "description": "高频风险向量",
          "items": {
            "type": "string"
          },
          "title": "Dominant Risk Vectors",
          "type": "array"
        }
      },
      "required": [
        "total_samples",
        "critical_count",
        "high_count",
        "medium_count",
        "low_count",
        "blocked_count",
        "top_warning_sample_ids",
        "dominant_risk_vectors"
      ],
      "title": "ReportSummary",
      "type": "object"
    },
    "ScenarioSnapshot": {
      "additionalProperties": false,
      "description": "报告中保留的样本快照。",
      "properties": {
        "destination_country": {
          "title": "Destination Country",
          "type": "string"
        },
        "product_name": {
          "title": "Product Name",
          "type": "string"
        },
        "trade_value_usd": {
          "title": "Trade Value Usd",
          "type": "number"
        },
        "payment_method": {
          "title": "Payment Method",
          "type": "string"
        },
        "incoterm": {
          "title": "Incoterm",
          "type": "string"
        },
        "deposit_ratio": {
          "title": "Deposit Ratio",
          "type": "number"
        }
      },
      "required": [
        "destination_country",
        "product_name",
        "trade_value_usd",
        "payment_method",
        "incoterm",
        "deposit_ratio"
      ],
      "title": "ScenarioSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "最终输出的协同预警报告。",
  "properties": {
    "report_id": {
      "description": "报告编号",
      "title": "Report Id",
      "type": "string"
    },
    "schema_version": {
      "description": "报告 Schema 版本",
      "title": "Schema Version",
      "type": "string"
    },
    "generated_at": {
      "description": "报告生成时间",
      "title": "Generated At",
      "type": "string"
    },
    "cruise_name": {
      "description": "巡航任务名称",
      "title": "Cruise Name",
      "type": "string"
    },
    "cruise_goal": {
      "description": "巡航目标",
      "title": "Cruise Goal",
      "type": "string"
    },
    "sample_set_id": {
      "description": "输入样本集标识",
      "title": "Sample Set Id",
      "type": "string"
    },
    "sample_count": {
      "description": "样本数量",
      "minimum": 0,
      "title": "Sample Count",
      "type": "integer"
    },
    "agent_roster": {
      "description": "Agent 编组",
      "items": {
        "$ref": "#/$defs/AgentRosterEntry"
      },
      "title": "Agent Roster",
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/ReportSummary",
      "description": "汇总统计"
    },
    "warnings": {
      "description": "样本级预警",
      "items": {
        "$ref": "#/$defs/CoordinatedWarning"
      },
      "title": "Warnings",
      "type": "array"
    },
    "final_watch_items": {
      "description": "总级别关注动作",
      "items": {
        "type": "string"
      },
      "title": "Final Watch Items",
      "type": "array"
    },
    "trace_context": {
      "additionalProperties": true,
      "description": "行动账本追踪上下文",
      "title": "Trace Context",
      "type": "object"
    }
  },
  "required": [
    "report_id",
    "schema_version",
    "generated_at",
    "cruise_name",
    "cruise_goal",
    "sample_set_id",
    "sample_count",
    "agent_roster",
    "summary",
    "warnings",
    "final_watch_items",
    "trace_context"
  ],
  "title": "ForeignTradeWarningReport",
  "type": "object"
}